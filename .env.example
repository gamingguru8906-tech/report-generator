# Razorpay (Dashboard -> Settings -> API Keys, and -> Webhooks)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxx
REPORT_AMOUNT_PAISE=49900          # legacy single-price fallback (in paise); per-product PRICE_* below are what drive checkout

# Optional per-product prices (paise). Omit any to use the app.py default shown.
# PRICE_COMPLETE=99900   # ₹999
# PRICE_CAREER=29900     # ₹299
# PRICE_FORECAST=49900   # ₹499
# PRICE_BUSINESS=49900   # ₹499
# PRICE_LOVE=25000       # ₹250
# PRICE_NAME=25000       # ₹250
# PRICE_MOBILE=25000     # ₹250
# PRICE_BABY=25000       # ₹250
# PRICE_SNAPSHOT=19900   # ₹199

# Google service account (one JSON, pasted whole). Share the Drive folder + Sheet with its email.
GOOGLE_SA_JSON={"type":"service_account", ...}
DRIVE_FOLDER_ID=xxxxxxxx
SHEET_ID=xxxxxxxx
SHEET_TAB=Orders

# Brevo (https://brevo.com — sends via HTTP API, works on Render where SMTP ports are blocked)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxx
BREVO_FROM_EMAIL=veshannastro@gmail.com            # must be a verified sender in Brevo
BREVO_FROM_NAME=Veshannastro

# Your site origins (for CORS on /create-order)
ALLOWED_ORIGINS=https://veshannastro.co.in,https://www.veshannastro.co.in

# Optional: real Amazon book cover image bundled in the repo
# BOOK_COVER_PATH=book_cover.jpg

# Protects the /admin diagnostic + recovery tools (any long random string)
ADMIN_TOKEN=
