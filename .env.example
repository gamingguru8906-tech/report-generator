# Razorpay (Dashboard -> Settings -> API Keys, and -> Webhooks)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxx
REPORT_AMOUNT_PAISE=49900          # ₹499 ; change to your price (in paise)

# Google service account (one JSON, pasted whole). Share the Drive folder + Sheet with its email.
GOOGLE_SA_JSON={"type":"service_account", ...}
DRIVE_FOLDER_ID=xxxxxxxx
SHEET_ID=xxxxxxxx
SHEET_TAB=Orders

# Gmail (App Password, needs 2-Step Verification on veshannastro@gmail.com)
SMTP_USER=veshannastro@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx

# Your site origins (for CORS on /create-order)
ALLOWED_ORIGINS=https://veshannastro.co.in,https://www.veshannastro.co.in

# Optional: real Amazon book cover image bundled in the repo
# BOOK_COVER_PATH=book_cover.jpg
